# mako notification daemon
# https://man.archlinux.org/man/mako.5

font=UbuntuSansMono Nerd Font 16
width=600
height=150
margin=16
outer-margin=0,0,22,0
padding=16
border-size=2
border-radius=5

background-color=#e5e9f0dd
text-color=#2e3440
border-color=#5e81ac
progress-color=over #d8dee9

default-timeout=10000
anchor=bottom-right

[urgency=critical]
background-color=#f8d7d5dd
text-color=#657b83
border-color=#dc322f
default-timeout=0
