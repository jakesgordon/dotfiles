#!/bin/bash

REALPATH=$(realpath $0)
DOTFILES=$(dirname $REALPATH)

BACKUP=$HOME/.backup
CONFIG=$HOME/.config
LOCAL=$HOME/.local/state
CLAUDE=$HOME/.claude
ONEDRIVE=$HOME/.config/onedrive

mkdir -p $BACKUP
mkdir -p $CONFIG
mkdir -p $LOCAL/DankMaterialShell
mkdir -p $CLAUDE
mkdir -p $ONEDRIVE

rm -rf $HOME/.bashrc
rm -rf $HOME/.gitconfig
rm -rf $HOME/.gitignore
rm -rf $HOME/.irbrc
rm -rf $HOME/.ripgreprc
rm -rf $HOME/.htoprc
rm -rf $HOME/.tool-versions
rm -rf $CONFIG/nvim
rm -rf $CONFIG/fish
rm -rf $CONFIG/niri
rm -rf $CONFIG/ghostty
rm -rf $CONFIG/lsd
rm -rf $CONFIG/mpd
rm -rf $CONFIG/ncdu
rm -rf $CONFIG/environment.d
rm -rf $CONFIG/user-dirs.dirs
rm -rf $CONFIG/user-dirs.conf
rm -rf $CONFIG/DankMaterialShell
rm -rf $LOCAL/DankMaterialShell/session.json
rm -rf $CLAUDE/settings.json
rm -rf $ONEDRIVE/config

ln -s $DOTFILES/bashrc                $HOME/.bashrc
ln -s $DOTFILES/gitconfig             $HOME/.gitconfig
ln -s $DOTFILES/gitignore             $HOME/.gitignore
ln -s $DOTFILES/irbrc                 $HOME/.irbrc
ln -s $DOTFILES/ripgreprc             $HOME/.ripgreprc
ln -s $DOTFILES/htoprc                $HOME/.htoprc
ln -s $DOTFILES/tool-versions         $HOME/.tool-versions
ln -s $DOTFILES/nvim                  $CONFIG/nvim
ln -s $DOTFILES/fish                  $CONFIG/fish
ln -s $DOTFILES/niri                  $CONFIG/niri
ln -s $DOTFILES/ghostty               $CONFIG/ghostty
ln -s $DOTFILES/lsd                   $CONFIG/lsd
ln -s $DOTFILES/mpd                   $CONFIG/mpd
ln -s $DOTFILES/ncdu                  $CONFIG/ncdu
ln -s $DOTFILES/environment.d         $CONFIG/environment.d
ln -s $DOTFILES/xdg/user-dirs.dirs    $CONFIG/user-dirs.dirs
ln -s $DOTFILES/xdg/user-dirs.conf    $CONFIG/user-dirs.conf
ln -s $DOTFILES/dms                   $CONFIG/DankMaterialShell
ln -s $DOTFILES/claude/settings.json  $CLAUDE/settings.json
ln -s $DOTFILES/onedrive/config       $ONEDRIVE/config
ln -s $DOTFILES/dms/session.json      $LOCAL/DankMaterialShell/session.json

enable_user_service() {
  systemctl --user cat "$1"        &>/dev/null || return  # skip: not installed
  systemctl --user is-enabled "$1" &>/dev/null && return  # skip: already enabled
  echo "enabling $1..."
  systemctl --user enable --now "$1"
}

enable_user_service mpd
enable_user_service mpd-mpris
