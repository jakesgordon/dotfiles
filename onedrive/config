# OneDrive client (abraunegg) configuration.
# Option reference: https://github.com/abraunegg/onedrive/blob/master/docs/application-config-options.md
#
# After provisioning, complete the one-time login with `onedrive` (opens a
# browser; paste the redirect URL back). Preview before the first real sync with
#   onedrive --sync --dry-run --verbose
# The systemd --user service (onedrive.service) runs `onedrive --monitor`.

sync_dir = "~/onedrive"

# monitor loop interval in seconds, used by the --user service
monitor_interval = "300"
